<!doctype html>
<html>
<head>
<meta charset="utf8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{{TITLE}}</title>
<style>
  :root{
    --bg:#eef1f6; --panel:#ffffff; --panel-2:#f6f8fc; --ink:#1a2130; --ink-soft:#5a6479;
    --line:#dde3ee; --line-strong:#c6cede; --accent:#5b6cf0; --accent-soft:#e7eafe;
    --ok:#15935a; --ok-soft:#dbf1e5; --run:#c67c07; --run-soft:#fdeecb;
    --wait:#8a93a8; --wait-soft:#e7ebf2; --fail:#d33a3a; --fail-soft:#fbe0e0;
    --mono:ui-monospace,"SF Mono",SFMono-Regular,Menlo,Consolas,monospace;
    --sans:system-ui,-apple-system,"Segoe UI",Roboto,sans-serif;
  }
  @media (prefers-color-scheme:dark){:root{
    --bg:#0d1017; --panel:#151a24; --panel-2:#10141d; --ink:#e6eaf2; --ink-soft:#98a2b6;
    --line:#232b3a; --line-strong:#33405a; --accent:#8b97ff; --accent-soft:#1e2440;
    --ok:#43c586; --ok-soft:#123726; --run:#f5b638; --run-soft:#3a2c0d;
    --wait:#7e889d; --wait-soft:#1c2230; --fail:#f2707a; --fail-soft:#3a1620;}}
  :root[data-theme="dark"]{
    --bg:#0d1017; --panel:#151a24; --panel-2:#10141d; --ink:#e6eaf2; --ink-soft:#98a2b6;
    --line:#232b3a; --line-strong:#33405a; --accent:#8b97ff; --accent-soft:#1e2440;
    --ok:#43c586; --ok-soft:#123726; --run:#f5b638; --run-soft:#3a2c0d;
    --wait:#7e889d; --wait-soft:#1c2230; --fail:#f2707a; --fail-soft:#3a1620;}
  :root[data-theme="light"]{
    --bg:#eef1f6; --panel:#ffffff; --panel-2:#f6f8fc; --ink:#1a2130; --ink-soft:#5a6479;
    --line:#dde3ee; --line-strong:#c6cede; --accent:#5b6cf0; --accent-soft:#e7eafe;
    --ok:#15935a; --ok-soft:#dbf1e5; --run:#c67c07; --run-soft:#fdeecb;
    --wait:#8a93a8; --wait-soft:#e7ebf2; --fail:#d33a3a; --fail-soft:#fbe0e0;}

  *{box-sizing:border-box}
  body{background:var(--bg);color:var(--ink);font-family:var(--sans);line-height:1.5;-webkit-font-smoothing:antialiased;margin:0}
  .wrap{max-width:1120px;margin:0 auto;padding:32px 24px 56px}
  .mono{font-family:var(--mono)}
  h1,h2,h3,h4{margin:0;text-wrap:balance}

  header{display:flex;flex-wrap:wrap;align-items:flex-start;justify-content:space-between;gap:16px;margin-bottom:22px}
  .eyebrow{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-soft)}
  h1{font-size:26px;font-weight:650;letter-spacing:-.01em;margin-top:4px}
  .sub{color:var(--ink-soft);font-size:14px;margin-top:3px;max-width:64ch}
  .statuspill{display:inline-flex;align-items:center;gap:8px;font-family:var(--mono);font-size:12px;font-weight:600;
    letter-spacing:.06em;text-transform:uppercase;padding:7px 13px;border-radius:999px;border:1px solid transparent}
  .statuspill.ok{background:var(--ok-soft);color:var(--ok);border-color:color-mix(in srgb,var(--ok) 30%,transparent)}
  .statuspill.run{background:var(--run-soft);color:var(--run);border-color:color-mix(in srgb,var(--run) 30%,transparent)}
  .statuspill.wait{background:var(--wait-soft);color:var(--wait);border-color:var(--line-strong)}
  .statuspill.fail{background:var(--fail-soft);color:var(--fail);border-color:color-mix(in srgb,var(--fail) 30%,transparent)}
  .dot{width:8px;height:8px;border-radius:50%;background:currentColor}
  .statuspill.run .dot{animation:pulse 1.8s infinite}
  @keyframes pulse{0%{box-shadow:0 0 0 0 color-mix(in srgb,var(--run) 60%,transparent)}70%{box-shadow:0 0 0 7px transparent}100%{box-shadow:0 0 0 0 transparent}}
  @media (prefers-reduced-motion:reduce){.dot,.card.run::before{animation:none}}

  .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:22px}
  .stat{background:var(--panel);border:1px solid var(--line);border-radius:12px;padding:14px 16px}
  .stat .k{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-soft);font-family:var(--mono)}
  .stat .v{font-size:22px;font-weight:650;margin-top:6px;font-variant-numeric:tabular-nums}
  .stat .v small{font-size:13px;color:var(--ink-soft);font-weight:500}
  .stat .s{font-size:12px;color:var(--ink-soft);margin-top:6px}
  .seg{display:flex;gap:4px;margin-top:10px;flex-wrap:wrap}
  .seg span{height:6px;flex:1 1 8px;min-width:8px;border-radius:3px;background:var(--wait-soft)}
  .seg span.on{background:var(--ok)} .seg span.cur{background:var(--run)} .seg span.bad{background:var(--fail)}

  .grid{display:grid;grid-template-columns:1.4fr 1fr;gap:16px;align-items:start}
  .panel{background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:20px}
  .panel h2{font-size:13px;letter-spacing:.06em;text-transform:uppercase;color:var(--ink-soft);font-family:var(--mono);margin-bottom:15px;display:flex;align-items:center;gap:8px}
  .badge{font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:.05em;padding:3px 8px;border-radius:6px;text-transform:uppercase}
  .badge.ok{background:var(--ok-soft);color:var(--ok)} .badge.run{background:var(--run-soft);color:var(--run)}
  .badge.wait{background:var(--wait-soft);color:var(--wait)} .badge.fail{background:var(--fail-soft);color:var(--fail)}

  .grp{border:1px solid var(--line);border-radius:11px;padding:12px;margin-bottom:12px;background:var(--panel-2)}
  .grp:last-child{margin-bottom:0}
  .grp h4{font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-soft);margin-bottom:9px;display:flex;align-items:center;justify-content:space-between;gap:8px}
  .card{border:1px solid var(--line);border-radius:9px;padding:10px 12px;background:var(--panel);margin-top:8px}
  .card:first-of-type{margin-top:0}
  .card.run{border-color:color-mix(in srgb,var(--run) 45%,var(--line))}
  .card.bad{border-color:color-mix(in srgb,var(--fail) 45%,var(--line))}
  .ctop{display:flex;align-items:center;justify-content:space-between;gap:10px}
  .part{font-family:var(--mono);font-size:11.5px;color:var(--ink-soft)} .part b{color:var(--ink)}
  .desc{font-size:13px;margin-top:3px}
  .meta{font-family:var(--mono);font-size:11px;color:var(--ink-soft);margin-top:7px;display:flex;gap:6px 12px;flex-wrap:wrap}
  .chip{font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;padding:3px 8px;border-radius:6px;white-space:nowrap}
  .chip.done{background:var(--ok-soft);color:var(--ok)} .chip.run{background:var(--run-soft);color:var(--run)}
  .chip.wait{background:var(--wait-soft);color:var(--wait)} .chip.bad{background:var(--fail-soft);color:var(--fail)}

  .gates{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:9px}
  .gates li{display:flex;gap:10px;font-size:12.5px;align-items:flex-start}
  .gates .tag{flex:none;font-family:var(--mono);font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;padding:2px 7px;border-radius:5px;margin-top:1px;background:var(--accent-soft);color:var(--accent)}
  .gates .tag.hard{background:var(--fail-soft);color:var(--fail)}

  .tl{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:11px}
  .tl li{display:grid;grid-template-columns:16px 1fr;gap:12px;font-size:13px}
  .tl .mk{width:10px;height:10px;border-radius:50%;margin-top:5px}
  .tl .ok{background:var(--ok)} .tl .run{background:var(--run)} .tl .fix{background:var(--accent)} .tl .bad{background:var(--fail)}
  .tl .t{font-family:var(--mono);font-size:11px;color:var(--ink-soft)}
  .foot{margin-top:22px;color:var(--ink-soft);font-size:12.5px;display:flex;flex-wrap:wrap;gap:6px 16px}
  .foot code{font-family:var(--mono);background:var(--panel);border:1px solid var(--line);padding:2px 6px;border-radius:5px;color:var(--ink)}
  @media (max-width:820px){.grid{grid-template-columns:1fr}.stats{grid-template-columns:repeat(2,1fr)}}
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div>
      <div class="eyebrow">{{EYEBROW}}</div>
      <h1>{{TITLE}}</h1>
      <div class="sub">{{SUBTITLE}}</div>
    </div>
    <div class="statuspill {{STATUS_CLASS}}"><span class="dot"></span>{{STATUS_LABEL}}</div>
  </header>

  <div class="stats">
    <div class="stat">
      <div class="k">Progress</div>
      <div class="v">{{DONE_COUNT}}<small> / {{TOTAL_COUNT}} verified</small></div>
      <div class="seg">{{PROGRESS_SEGMENTS}}</div>
    </div>
    <div class="stat">
      <div class="k">Iteration</div>
      <div class="v">{{ITERATION}}</div>
      <div class="s">last run · {{LAST_TIMESTAMP}}</div>
    </div>
    <div class="stat">
      <div class="k">Last outcome</div>
      <div class="v" style="font-size:16px;padding-top:5px">{{LAST_OUTCOME}}</div>
      <div class="s">exit code · {{LAST_EXIT}}</div>
    </div>
    <div class="stat">
      <div class="k">Open items</div>
      <div class="v">{{OPEN_COUNT}}</div>
      <div class="s">{{OPEN_SUMMARY}}</div>
    </div>
  </div>

  <div class="grid">
    <div class="panel">
      <h2>Work items <span class="badge {{STATUS_CLASS_BADGE}}">{{DONE_COUNT}}/{{TOTAL_COUNT}} verified</span></h2>
      {{GROUP_CARDS}}
    </div>

    <div class="panel">
      <h2>Gates &amp; budget</h2>
      <ul class="gates">
        {{GATES_ROWS}}
      </ul>
    </div>
  </div>

  <div class="panel" style="margin-top:16px">
    <h2>Recent activity</h2>
    <ul class="tl">
      {{TIMELINE_ROWS}}
    </ul>
  </div>

  <div class="foot">
    <span>Rendered from <code>{{STATE_PATH}}</code> at <code>{{GENERATED_AT}}</code> — auto-updates on each loop tick.</span>
    <span>Grouped by the loop's decomposition · verifier gates each item.</span>
  </div>
</div>
</body>
</html>
